# ===== LLM & Embedding =====
DASHSCOPE_API_KEY=sk-xxx          # 阿里云 DashScope API Key

# ===== Qwen 模型选择 =====
LLM_MODEL=qwen-plus               # 主力模型（摘要/页面生成）
LLM_FAST_MODEL=qwen-turbo         # 快速模型（清洗等轻量任务）
LLM_MAX_MODEL=qwen-max            # 最强模型（复杂推理，可选）
EMBEDDING_MODEL=text-embedding-v3

# ===== Milvus =====
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== 存储 =====
KB_BASE_DIR=./knowledge_bases

# ===== 爬虫 =====
CRAWLER_DELAY_SECONDS=1.0
CRAWLER_MAX_CONCURRENT=5

# ===== 处理参数 =====
EXTRACTION_BATCH_SIZE=20          # 每批抽取的文档数
LLM_MAX_CONCURRENT=3              # LLM 最大并发数
